Bootstrap: docker
From: nvcr.io/nvidia/nvhpc:25.9-devel-cuda_multi-ubuntu24.04

%post
    # NVIDIA HPC SDK
    HPCSDK_VERSION=25.9
    CUDA_VERSION=12.9
    OPENMPI_VERSION=4.1.8
    NEURON_VERSION=8.2.7

    # Make them available in runtime environment
    echo "export HPCSDK_VERSION=${HPCSDK_VERSION}" >> $SINGULARITY_ENVIRONMENT
    echo "export CUDA_VERSION=${CUDA_VERSION}" >> $SINGULARITY_ENVIRONMENT
    echo "export OPENMPI_VERSION=${OPENMPI_VERSION}" >> $SINGULARITY_ENVIRONMENT

    echo ">>> Updating system and installing dependencies..."
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get upgrade -y

    echo ">>> Installing core development tools and libraries..."
    apt-get install -y \
        build-essential \
        cmake \
        git \
        wget \
        bison \
        flex \
        libreadline-dev \
        libxcomposite-dev \
        libbz2-dev \
        libffi-dev \
        python3-setuptools \
        python3-wheel \
        python3-dev \
        python3-pip \
        python3-venv \
        libslurm-dev \
        libpmix-dev \
        libssl-dev \
        zlib1g-dev \
        libx11-dev \
        libxt-dev \
        libxext-dev \
        libxft-dev \
        libxpm-dev \
        libncurses-dev \
        perl \
        vim \
        lsb-release \
        sqlite3 \
        less

    echo ">>> Creating compiler symlinks..."
    ln -s /opt/nvidia/hpc_sdk/Linux_x86_64/${HPCSDK_VERSION}/compilers/bin/nvc /usr/local/bin/nvc
    ln -s /opt/nvidia/hpc_sdk/Linux_x86_64/${HPCSDK_VERSION}/compilers/bin/nvc++ /usr/local/bin/nvc++

    # --- Build and install OpenMPI with PMI support ---
    echo ">>> Building OpenMPI with PMI support version ${OPENMPI_VERSION}..."
    cd /opt
    OPENMPI_MAJOR_MINOR=$(echo ${OPENMPI_VERSION} | cut -d. -f1,2)
    wget https://download.open-mpi.org/release/open-mpi/v${OPENMPI_MAJOR_MINOR}/openmpi-${OPENMPI_VERSION}.tar.gz
    tar xzf openmpi-${OPENMPI_VERSION}.tar.gz
    rm openmpi-${OPENMPI_VERSION}.tar.gz
    cd openmpi-${OPENMPI_VERSION}
    ./configure --prefix=/opt/openmpi
    make -j12
    make install

    # Set up environment for rest of the build
    export PATH=/opt/openmpi/bin:$PATH
    export LD_LIBRARY_PATH=/opt/openmpi/lib:/lib64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}


    # --- Python venv and modules ---
    echo ">>> Detecting Python version..."
    PYTHON_VERSION=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
    echo ">>> Detected Python version: ${PYTHON_VERSION}"
    echo "export PYTHON_VERSION=${PYTHON_VERSION}" >> $SINGULARITY_ENVIRONMENT

    echo ">>> Creating Python virtual environment at /opt/venv..."
    python3 -m venv /opt/venv
    /opt/venv/bin/pip install --upgrade pip
    /opt/venv/bin/pip install numpy scipy matplotlib pandas networkx scikit-learn sympy wheel setuptools Cython jinja2 lxml pyyaml mpi4py

    # --- Build and install NEURON with CoreNEURON ---
    echo ">>> Building and installing NEURON with CoreNEURON..."
    cd /opt
    # git clone https://github.com/neuronsimulator/nrn.git
    # Download and extract NEURON source tarball using wget
    wget https://github.com/neuronsimulator/nrn/releases/download/${NEURON_VERSION}/nrn-full-src-package-${NEURON_VERSION}.tar.gz
    tar -xvzf nrn-full-src-package-${NEURON_VERSION}.tar.gz
    mv nrn-${NEURON_VERSION} nrn
    rm nrn-full-src-package-${NEURON_VERSION}.tar.gz
    cd nrn
    mkdir build

    # Set environment variables for NEURON build
    export NVHPC=/opt/nvidia/hpc_sdk
    export CUDA_HOME=$NVHPC/Linux_x86_64/${HPCSDK_VERSION}/cuda/${CUDA_VERSION}
    export CUDA_ROOT=$CUDA_HOME
    export PATH=$NVHPC/Linux_x86_64/${HPCSDK_VERSION}/compilers/bin:$CUDA_HOME/bin:/opt/openmpi/bin:$PATH
    export LD_LIBRARY_PATH=$NVHPC/Linux_x86_64/${HPCSDK_VERSION}/compilers/lib:$CUDA_HOME/lib64:/opt/openmpi/lib:/lib64:$LD_LIBRARY_PATH
    export VIRTUAL_ENV=/opt/venv
    export PATH="$VIRTUAL_ENV/bin:$PATH"
    export PYTHONPATH="$VIRTUAL_ENV/lib/python${PYTHON_VERSION}/site-packages:$PYTHONPATH"

    echo ">>> INSTALLING CORENEURON..."
    cd /opt/nrn/build
    cmake .. \
        -DNRN_ENABLE_CORENEURON=ON \
        -DCORENRN_ENABLE_GPU=ON \
        -DNRN_ENABLE_INTERVIEWS=OFF \
        -DNRN_ENABLE_RX3D=OFF \
        -DCMAKE_INSTALL_PREFIX=/opt/nrn-install \
        -DCMAKE_C_COMPILER=nvc \
        -DCMAKE_CXX_COMPILER=nvc++ \
        -DCMAKE_CUDA_ARCHITECTURES="75" \
        -DCMAKE_CXX_FLAGS="-O3 -g" \
        -DCMAKE_C_FLAGS="-O3 -g" \
        -DCMAKE_BUILD_TYPE=Custom

    make VERBOSE=1 -j12  2>&1 | tee build.log
    make install

    export PATH=/opt/nrn-install/bin:$PATH
    export PYTHONPATH=/opt/nrn-install/lib/python:$PYTHONPATH

    # --- Automatically detect and export NMODL_PYLIB ---
    PYLIB=$(find /usr/lib /lib /usr/local/lib -name "libpython3.*.so" | grep -m1 -E "libpython3\.[0-9]+\.so")
    export NMODL_PYLIB=$PYLIB
    echo ">>> NMODL_PYLIB set to: $NMODL_PYLIB"

    # --- Make persistent in container environment ---
    echo "export NMODL_PYLIB=$NMODL_PYLIB" >> $SINGULARITY_ENVIRONMENT
    echo "export NMODLHOME=/opt/nrn-install" >> $SINGULARITY_ENVIRONMENT

    #export NMODL_PYLIB=/usr/lib/x86_64-linux-gnu/libpython${PYTHON_VERSION}.so  # This was obtained after it sandbox check

    rm -rf /opt/openmpi-${OPENMPI_VERSION}
    rm -rf /opt/nrn



%environment

    # Activate Python virtual environment automatically
    export VIRTUAL_ENV=/opt/venv
    export PATH="$VIRTUAL_ENV/bin:$PATH"
    export PYTHONPATH="$VIRTUAL_ENV/lib/python${PYTHON_VERSION}/site-packages:$PYTHONPATH"

    # NVIDIA HPC SDK and CUDA environment
    export NVHPC=/opt/nvidia/hpc_sdk
    export CUDA_HOME=$NVHPC/Linux_x86_64/${HPCSDK_VERSION}/cuda/${CUDA_VERSION}
    export CUDA_ROOT=$CUDA_HOME

    # OpenMPI, NVIDIA, and CUDA in PATH and LD_LIBRARY_PATH
    export PATH=/opt/nrn-install/bin:/opt/openmpi/bin:$NVHPC/Linux_x86_64/${HPCSDK_VERSION}/compilers/bin:$CUDA_HOME/bin:$PATH
    export LD_LIBRARY_PATH=/opt/nrn-install/lib:/opt/openmpi/lib:$NVHPC/Linux_x86_64/${HPCSDK_VERSION}/compilers/lib:$CUDA_HOME/lib64:/lib64:$LD_LIBRARY_PATH
    export PYTHONPATH=/opt/nrn-install/lib/python:$PYTHONPATH
